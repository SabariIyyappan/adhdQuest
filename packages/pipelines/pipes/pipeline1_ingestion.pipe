{
  "components": [
    {
      "id": "webhook_1",
      "provider": "webhook",
      "config": { "hideForm": true, "mode": "Source", "parameters": {}, "type": "webhook" },
      "ui": { "position": { "x": 20, "y": 220 }, "measured": { "width": 150, "height": 66 } }
    },
    {
      "id": "agent_rocketride_1",
      "provider": "agent_rocketride",
      "config": {
        "agent_description": "ADHDQuest Pipeline 1 — Ingestion & Game Generation.",
        "instructions": [
          "Input is Contract A: { child_id, assignment_id, pdf_storage_url, child_profile }.",
          "1) OCR the PDF (tool_python: pipelines.nodes.ocr_node.run) -> raw text.",
          "2) NER (tool_python: pipelines.nodes.ner_node.run) -> tagged questions (topic + difficulty 1-5).",
          "3) Score assignment metadata (fast tier).",
          "4) Cognee recall prior behavioural context (tool_python: pipelines.nodes.cognee_nodes.recall).",
          "5) Generate the personalized game spec (strong tier): easy->hard, front-load remembered struggle topics before fatigue, assign a mechanic per topic, insert breather checkpoints, fail_threshold=3.",
          "6) Daytona (tool_daytona): create from snapshot adhdquest-pygame-base, write game.py, validate, critic-repair up to 3x, return preview URL.",
          "7) Output (tool_butterbase): upsert the sessions row + KV session state, then publish Contract C game_ready on child:{child_id}:session. Return Contract B."
        ],
        "max_waves": 12,
        "parameters": {}
      },
      "input": [{ "lane": "questions", "from": "webhook_1" }],
      "ui": { "position": { "x": 260, "y": 220 }, "measured": { "width": 150, "height": 86 } }
    },
    {
      "id": "llm_gemini_1",
      "provider": "llm_gemini",
      "config": {
        "profile": "custom",
        "custom": {
          "apikey": "${ROCKETRIDE_GEMINI_KEY}",
          "model": "gemini-2.0-flash",
          "modelTotalTokens": 1048576,
          "outputTokens": 8192
        }
      },
      "control": [{ "classType": "llm", "from": "agent_rocketride_1" }],
      "ui": { "position": { "x": 120, "y": 400 }, "measured": { "width": 150, "height": 66 } }
    },
    {
      "id": "memory_internal_1",
      "provider": "memory_internal",
      "config": { "type": "memory_internal" },
      "control": [{ "classType": "memory", "from": "agent_rocketride_1" }],
      "ui": { "position": { "x": 300, "y": 400 }, "measured": { "width": 150, "height": 66 } }
    },
    {
      "id": "tool_python_1",
      "provider": "tool_python",
      "config": { "type": "tool_python", "allowedModules": ["pipelines", "json", "math", "re"], "timeout": 120 },
      "control": [{ "classType": "tool", "from": "agent_rocketride_1" }],
      "ui": { "position": { "x": 480, "y": 400 }, "measured": { "width": 150, "height": 40 } }
    },
    {
      "id": "tool_daytona_1",
      "provider": "tool_daytona",
      "config": {
        "type": "tool_daytona",
        "apikey": "${ROCKETRIDE_DAYTONA_KEY}",
        "api_url": "${ROCKETRIDE_DAYTONA_URL}",
        "snapshot": "adhdquest-pygame-base",
        "language": "python",
        "auto_stop_minutes": 60,
        "exec_timeout_secs": 120,
        "max_output_chars": 10000
      },
      "control": [{ "classType": "tool", "from": "agent_rocketride_1" }],
      "ui": { "position": { "x": 640, "y": 400 }, "measured": { "width": 150, "height": 40 } }
    },
    {
      "id": "tool_butterbase_1",
      "provider": "tool_butterbase",
      "config": {
        "type": "tool_butterbase",
        "bearer": "${ROCKETRIDE_BUTTERBASE_KEY}",
        "endpoint": "${ROCKETRIDE_BUTTERBASE_URL}",
        "serverName": "adhdquest"
      },
      "control": [{ "classType": "tool", "from": "agent_rocketride_1" }],
      "ui": { "position": { "x": 800, "y": 400 }, "measured": { "width": 150, "height": 40 } }
    },
    {
      "id": "response_answers_1",
      "provider": "response_answers",
      "config": { "laneName": "answers" },
      "input": [{ "lane": "answers", "from": "agent_rocketride_1" }],
      "ui": { "position": { "x": 500, "y": 220 }, "measured": { "width": 150, "height": 66 } }
    }
  ],
  "project_id": "a9031797-da57-46dc-b843-f7130c413258",
  "viewport": { "x": 0, "y": 0, "zoom": 1 },
  "version": 1
}
