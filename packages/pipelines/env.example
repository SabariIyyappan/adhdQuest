# ADHDQuest pipelines — RocketRide environment (Person B)
#
# ROCKETRIDE_URI and ROCKETRIDE_APIKEY are auto-managed by the RocketRide VS Code
# extension from its settings — do NOT edit those by hand. The variables below are
# the custom ones referenced with ${ROCKETRIDE_*} inside the .pipe files, so the
# canvases run once you fill them in. Only ROCKETRIDE_-prefixed vars are substituted.

# --- Auto-managed by the extension (shown for reference) ---
ROCKETRIDE_URI=https://api.rocketride.ai
ROCKETRIDE_APIKEY=your-rocketride-api-key

# --- Daytona (tool_daytona) — Person B ---
ROCKETRIDE_DAYTONA_KEY=your-daytona-api-key
ROCKETRIDE_DAYTONA_URL=https://app.daytona.io/api

# --- Butterbase (tool_butterbase) — from Person A ---
ROCKETRIDE_BUTTERBASE_KEY=your-butterbase-service-key
ROCKETRIDE_BUTTERBASE_URL=https://<your-app>.butterbase.dev

# --- Optional: strong-model key if a .pipe uses the 'custom' llm_anthropic profile ---
ROCKETRIDE_ANTHROPIC_KEY=sk-ant-...
